{%- if section.settings.use_dummy_product and collections['all'].products.size > 0 -%}
    {%- assign product = collections['all'].products[0] -%}
{%- endif -%}

{%- if section.settings.product != blank -%}
    {%- assign product = all_products[section.settings.product] -%}
{%- endif -%}

{%- if product != blank -%}
{%- assign variant_images = product.images | where: 'attached_to_variant?', true | map: 'src' -%}

{%- if section.settings.desktop_media_grid -%}
    <div class="product-media-grid-container">
        <div class="product-media-grid desktop" collapsible="{% if section.settings.collapse_media %}true{% else %}false{% endif %}">
            <div class="product-media-grid-row">
            {% for media in product.media %}
                {%- if media.media_type == "image" and section.settings.show_variant_media == false and variant_images contains media.src -%}
                    {%- continue -%}
                {%- endif -%}

                {%- if media.media_type == "image" -%}
                    {% render 'image', image: media.preview_image %}
                {%- elsif media.media_type == "video" -%}
                    {{ media | video_tag: image_size: "2048x", autoplay: true, loop: true, controls: false, muted: section.settings.mute_videos }}
                {%- elsif media.media_type == "model" -%}
                    {{ media | model_viewer_tag }}
                {%- endif -%}

                {%- if forloop.index0 == 0 -%}
                    </div>
                    <div class="product-media-grid-row">
                {%- elsif forloop.last == false -%}
                    {% assign new_row = forloop.index0 | minus: 1 | modulo: 2 %}
                    {%- if new_row == 1 -%}
                        </div>
                        <div class="product-media-grid-row">
                    {%- endif -%}
                {%- endif -%}
            {% endfor %}
            </div>
        </div>
        {%- if section.settings.collapse_media -%}
            {%- capture collapse_button_style -%}
                background-color: {{ section.settings.collapse_button_background_color }};
                color: {{ section.settings.collapse_button_text_color }};
                font-size: {{ section.settings.collapse_button_font_size }}px;
            {%- endcapture -%}
            <div {% render 'overwrite-theme-style', append_style: collapse_button_style %} class="btn show-toggle-btn">
                <span text-show-more="{{ 'product.collapsible_button_show_more' | t }}" text-show-less="{{ 'product.collapsible_button_show_less' | t }}">
                    {{ 'product.collapsible_button_show_more' | t }}
                </span> 
                {% render 'icon-arrow-down', custom_style: true, height: section.settings.collapse_button_font_size, width: section.settings.collapse_button_font_size %}
            </div>
        {%- endif -%}
        <div class="product-media-collapsible-content-desktop-container"></div>
    </div>
{%- endif -%}

<div class="product-media {% if section.settings.mobile_full_width == false %}container-only-mobile{% endif %} {% if section.settings.show_rounded_corners %} product-media-rounded-corners {% endif %} {% if section.settings.desktop_media_grid %} mobile{% endif %} {% if section.settings.desktop_media_slide_fixed_top %} product-media-sticky {% endif %}">
    <div class="product-media-main swiper" 
        data-thumbnails="{{ section.settings.show_thumbnails }}" 
        data-mobile-vertical="{{ section.settings.mobile_vertical }}" 
        data-mobile-full-width="{{ section.settings.mobile_full_width }}"
        data-space-between-thumbnails="{{ section.settings.space_between_thumbnails }}"
        data-desktop-navigation="{{ section.settings.desktop_main_slider_navigation }}" 
        data-mobile-navigation="{{ section.settings.mobile_main_slider_navigation }}" 
        data-desktop-media-fixed="false">
        <div class="swiper-wrapper">
            {% for media in product.media %}
                {%- if media.media_type == "image" and section.settings.show_variant_media == false and variant_images contains media.src -%}
                    {%- continue -%}
                {%- endif -%}

                <div class="swiper-slide">
                    {%- if media.media_type == "image" -%}
                        {% render 'image', image: media.preview_image %}
                    {%- elsif media.media_type == "video" -%}
                        {{ media | video_tag: image_size: "2048x", autoplay: false, loop: true, controls: false, muted: section.settings.mute_videos }}
                    {%- elsif media.media_type == "model" -%}
                        {{ media | model_viewer_tag }}
                    {%- endif -%}
                </div>
            {% endfor %}
        </div>
    
        {%- if section.settings.show_pagination_dots -%}
            <div class="swiper-pagination {% if section.settings.mobile_vertical %} product-media-main-vertical-swiper-pagination {% endif %}"></div>
        {%- endif -%}

        {%- if section.settings.desktop_main_slider_navigation or section.settings.mobile_main_slider_navigation -%}
            <div class="swiper-button-prev"></div>
            <div class="swiper-button-next"></div>
        {%- endif -%}

        {%- if section.settings.show_badge -%}
            {%- capture badge_style -%}
                border-radius: {{ section.settings.badge_border_radius }}px;
            {%- endcapture -%}

            {% assign badge_value = blank %}
            {% assign tags = product.tags | join: '{{}}' | downcase | split: '{{}}' %}
            
            {%- if tags contains 'bestseller' -%}
                {% assign badge_value = 'product.badge_bestseller' | t %}
            {%- elsif product.selected_or_first_available_variant.available == false -%}
                {% assign badge_value = 'product.badge_sold_out' | t %}
            {%- elsif product.selected_or_first_available_variant.compare_at_price > product.selected_or_first_available_variant.price and product.available -%}
                {% assign badge_value = 'product.badge_sale' | t %}
            {%- endif -%}

            {%- if badge_value != blank -%}
                <div class="product-media-main-badge {% if product.selected_or_first_available_variant.available == false %} product-media-main-badge-sold-out {% endif %} font-heading" {% render 'overwrite-theme-style', settings: section.settings, append_style: badge_style %}>{{ badge_value }}</div>
            {%- endif -%}
        {%- endif -%}
    </div>

    {%- if section.settings.show_thumbnails -%}
        <div class="product-media-thumbnail swiper {% if section.settings.animate_thumbnails %} product-media-thumbnail-animated{% endif %}" style="margin-top: {{ section.settings.space_between_thumbnails }}px;">
            <div class="swiper-wrapper">
                {% for media in product.media %}
                    {%- if media.media_type == "image" and section.settings.show_variant_media == false and variant_images contains media.src -%}
                        {%- continue -%}
                    {%- endif -%}
                    
                    <div class="swiper-slide">
                        {%- if media.media_type == "image" -%}
                            {% render 'image', image: media.preview_image %}
                        {%- elsif media.media_type == "video" -%}
                            {% render 'image', image: media.preview_image %}
                        {%- elsif media.media_type == "model" -%}
                            {% render 'image', image: media.preview_image %}
                        {%- endif -%}
                    </div>
                {% endfor %}
            </div>
        </div>
    {%- endif -%}

    <div class="product-media-collapsible-content-desktop-container"></div>
</div>

<div class="product-information container-only-mobile">

{%- assign product_page_button_exists = false -%}
{%- assign product_set_exists = false -%}

{%- for block in section.blocks -%}
{% case block.type %}
    {% when "set_discounts" %}
        {%- assign product_set_exists = true -%}
        {%- break -%}
{% endcase %}
{%- endfor -%}

{%- assign form_class = "" -%}

{%- if section.settings.use_border -%}
  {%- assign form_class = form_class | append: "product-add-to-cart-form" -%}
  {%  capture form_style %}  
    --form_border_radius: {{ section.settings.form_border_radius }}px;
    --form_outer_border_color: {{ section.settings.form_outer_border_color}};
    --form_inner_border_color: {{ section.settings.form_inner_border_color}};
  {% endcapture %}
{%- endif -%}

{%- form 'product', product, data-type: 'add-to-cart-form', id: 'product-add-to-cart-form', class: form_class, style: form_style -%}

{%- for block in section.blocks -%}
{% case block.type %}

    {%- when '@app' -%}
        {% render block %}
    {% when "social_proof" %}
        <div class="ccpc ccpc-display product-information-social-proof {% if block.settings.show_mobile_fullscreen == true %} container-anti-container-only-mobile{% else %}product-information-social-proof-not-fullscreen{% endif %}" {% render 'overwrite-theme-style', settings: block.settings %}>
            <div class="container-only-mobile">
                <div>
                    {%- capture image_style -%}
                        width: {{ block.settings.image_size }}px;
                        height: {{ block.settings.image_size }}px;

                        {%- if block.settings.border_color != blank -%}
                            {%- assign alpha = block.settings.border_color | color_extract: 'alpha' -%}
                    
                            {%- if alpha == 1 -%}
                                border: 2px solid {{ block.settings.border_color | color_to_hex }}; 
                                padding: 1px;
                                background-color: {{ block.settings.overwrite_theme_background_color | color_to_hex }};
                            {%- endif -%}
                        {%- endif -%}
                    {%- endcapture -%}

                    {%- assign image_1_placeholder = blank -%}
                    {%- assign image_2_placeholder = blank -%}

                    {% if block.settings.show_placeholder %}
                        {% if block.settings.image_1 == blank %}
                            {%- assign image_1_placeholder = 'conrise-placeholder-man.jpg' -%}
                        {% endif %}
                        {% if block.settings.image_2 == blank %}
                            {%- assign image_2_placeholder = 'conrise-placeholder-woman.jpg' -%}
                        {% endif %}
                    {% endif %}

                    {% render 'image', image: block.settings.image_1, assetName: image_1_placeholder, style: image_style %}
                    {% render 'image', image: block.settings.image_2, assetName: image_2_placeholder, style: image_style %}
                </div>
                <p>
                    {%- capture verified_icon -%}
                        <img src="{{ "Icon-Verified.png" | asset_url }}" />
                    {%- endcapture -%}

                    {{ block.settings.text | replace: "[verified]", verified_icon }}
                </p>
            </div>
        </div>

    {% when "title" %}
        <h1 {% render 'overwrite-theme-style', settings: block.settings %}><a href="{{ product.url }}" class="no-link-style">{{ product.title }}</a></h1>
    
    {% when "sku" %}
        <h1 class="{% if block.settings.mobile_above_media %} product-move-above-media {% endif %} {{ product.id }}-product-sku" {% render 'overwrite-theme-style', settings: block.settings %}>{{ product.selected_or_first_available_variant.sku }}</h1>

    {% when "text" %}
        {%- capture text_style -%}
            {%- if block.settings.overwrite_theme_background_color != blank -%}
                {%- assign alpha = block.settings.overwrite_theme_background_color | color_extract: 'alpha' -%}
        
                {%- if alpha == 1 -%}
                    border-radius: var(--border-radius);
                    padding: 14px 17px;
                    box-sizing: border-box;
                {%- endif -%}
            {%- endif -%}
        {%- endcapture -%}

        <div class="product-information-text" {% render 'overwrite-theme-style', settings: block.settings, append_style: text_style %}>{{ block.settings.text }}</div>

    {% when "reviews" %}
        <div {% render 'overwrite-theme-style', settings: block.settings %}>
            {%- if block.settings.show_dummy and settings.review_app == 'none' -%}
                {% assign stars = block.settings.stars %}
                {% assign number = block.settings.number_of_reviews %}

                {%- if block.settings.review_stars_metafield != blank -%}
                    {% assign metafield_brackets = block.settings.review_stars_metafield | split: "." %}
                    {% assign metafield_brackets_size = metafield_brackets | size %}

                    {% if metafield_brackets_size < 2 %}
                        {% assign stars = product.metafields[metafield_brackets[0]] %}
                    {% else if metafield_brackets_size == 2 %}
                        {% assign stars = product.metafields[metafield_brackets[0]][metafield_brackets[1]] %}
                    {% endif %}
                {%- endif -%}

                {%- if block.settings.review_number_metafield != blank -%}
                    {% assign metafield_brackets = block.settings.review_number_metafield | split: "." %}
                    {% assign metafield_brackets_size = metafield_brackets | size %}

                    {% if metafield_brackets_size < 2 %}
                        {% assign number = product.metafields[metafield_brackets[0]] %}
                    {% else if metafield_brackets_size == 2 %}
                        {% assign number = product.metafields[metafield_brackets[0]][metafield_brackets[1]] %}
                    {% endif %}
                {% endif %}

                <div class="product-reviews-dummy">
                    <div class="product-reviews-dummy-stars">
                        {% assign star_id = section.id | append: block.id %}
                        {% render 'review-stars', stars: stars, id: star_id %}
                    </div>
                    <span>({{ number }})</span>
                </div>
            {%- else -%}
                {% render 'review-widget', type: "badge" %}
            {%- endif -%}
        </div>

    {% when "price" %}
        <div class="product-information-price {% if block.settings.use_heading_font %} font-heading{% endif %}" {% render 'overwrite-theme-style', settings: block.settings %}>
            {%- if block.settings.price_note_display -%}
                {%- capture note_style -%}
                    border-radius: {{ block.settings.price_note_border_radius }}px;
                    font-size: {{ block.settings.price_note_font_size }}px;
                    background-color: {{ block.settings.price_note_color | color_to_hex }};
                    color: {{ block.settings.price_note_text_color | color_to_hex }};
                {%- endcapture -%}

                <div class="product-information-price-per-unit" 
                    style="{{ note_style | strip_newlines | strip }}"
                    data-pattern="{{ block.settings.price_note_text }}">
                    {{ block.settings.price_note_text }}
                </div>
                <div class="product-information-price-per-unit-arrow" style="border-top-color: {{ block.settings.price_note_color | color_to_hex }};"></div>
            {%- endif -%}
            
            <div class="product-information-price-container">
            {% render 'price', product: product, use_variant: true, show_compare_price: true, discounted_price_text_color: block.settings.overwrite_theme_discounted_price_text_color %}

            {%- if block.settings.badge_type != 'no' and settings.show_compare_price != 'no' -%}
                {%- capture style -%}
                    border-radius: {{ block.settings.badge_border_radius }}px;
                    background-color: {{ block.settings.badge_color | color_to_hex }};
                    color: {{ block.settings.badge_text_color | color_to_hex }};
                    --product-information-price-saved-tag-fill: {{ block.settings.badge_text_color | color_to_hex }};

                    {% if product.selected_or_first_available_variant.compare_at_price == blank or product.selected_or_first_available_variant.compare_at_price <= product.selected_or_first_available_variant.price %}
                        display: none;
                    {% endif %}

                    {% if block.settings.badge_font_size > 0 %}
                        font-size: {{ block.settings.badge_font_size }}px;
                    {% endif %}
                {%- endcapture -%}

                <div class="product-information-price-saved" data-type="{{ block.settings.badge_type }}" style="{{ style | strip_newlines | strip }}">
                    {%- capture icon_style -%}
                        {% if block.settings.badge_font_size > 0 %}
                            width: {{ block.settings.badge_font_size | times: 1.2 }}px;
                            height: {{ block.settings.badge_font_size | times: 1.2 }}px;
                        {% endif %}
                    {%- endcapture -%}
                    {% render 'icon-tag', style: icon_style %} {{ 'product.price_saving' | t }}&nbsp;
                    
                    <span>
                        {%- if block.settings.badge_type == 'percentage' -%}
                            {{ product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price | times: 100 | divided_by: product.selected_or_first_available_variant.compare_at_price }}%
                        {%- else -%}
                            {%- assign price = product.selected_or_first_available_variant.compare_at_price | minus: product.selected_or_first_available_variant.price -%}
                            {% render 'price', price: price %}
                        {%- endif -%}
                    </span>
                </div>    
            {%- endif -%}
            </div>
        </div>

        {% if block.settings.price_note_variant_metafield != blank %}
            <script>
                window.cr_priceNoteVariantMetafields = {};
            
                {% for variant in product.variants %}
                    {% assign metafield_brackets = block.settings.price_note_variant_metafield | split: "." %}
                    {% assign metafield_brackets_size = metafield_brackets | size %}
                    {% assign multiplier = 0 %}

                    {% if metafield_brackets_size < 2 %}
                        {% assign multiplier = variant.metafields[metafield_brackets[0]].value %}
                    {% else if metafield_brackets_size == 2 %}
                        {% assign multiplier = variant.metafields[metafield_brackets[0]][metafield_brackets[1]].value %}
                    {% endif %}

                    window.cr_priceNoteVariantMetafields[{{- variant.id -}}] = {{ multiplier }};
                {% endfor %}
            </script>
        {% endif %}

    {% when "net_price" %}
        <div class="product-information-price {% if block.settings.mobile_above_media %} product-move-above-media {% endif %} {% if block.settings.use_heading_font %} font-heading{% endif %}" {% render 'overwrite-theme-style', settings: block.settings %}>
            {% render 'price_net', product: product, use_variant: true, product_tax_rate: block.settings.tax_rate, settings: block.settings %}
        </div>

    {% when "unit_price" %}
        {%- capture style -%}
            {% if product.selected_or_first_available_variant.unit_price_measurement == blank %}
                display: none;
            {% endif %}
        {%- endcapture -%}

        <div class="product-information-unit-price" {% render 'overwrite-theme-style', settings: block.settings, append_style: style %}>
            <div class="product-information-unit-price-price">{% render 'price', price: product.selected_or_first_available_variant.unit_price %}</div>
            /
            <div class="product-information-unit-price-unit">{{ product.selected_or_first_available_variant.unit_price_measurement.reference_value }}{{ product.selected_or_first_available_variant.unit_price_measurement.reference_unit }}</div>
        </div>

    {% when "bullet_points" %}
        {%- capture style -%}
            {% if block.settings.space_between_points > 0 %}
                grid-gap: {{ block.settings.space_between_points }}px;
                
                {% if block.settings.two_columns %}
                    margin-right: {{ block.settings.space_between_points }}px;
                {% endif %}
            {% endif %}

            {% if block.settings.space_between_points == 0 or block.settings.two_columns == false %}
                background-color: {{ block.settings.background_color }};
            {% endif %}

            {%- if block.settings.margin_top != 0 -%}
                margin-top: {{ block.settings.margin_top }}px;
            {%- endif -%}
            {%- if block.settings.margin_bottom != 0 -%}
                margin-bottom: {{ block.settings.margin_bottom }}px;
            {%- endif -%}
        {%- endcapture -%}

        {%- capture div_style -%}
            {% if block.settings.space_between_points > 0 and block.settings.two_columns %}
                background-color: {{ block.settings.background_color }};
            {% endif %}

            {%- if block.settings.padding_vertical != 0 -%}
                padding-top: {{ block.settings.padding_vertical }}px;
                padding-bottom: {{ block.settings.padding_vertical }}px;
            {%- endif -%}
            {%- if block.settings.padding_horizontal != 0 -%}
                padding-left: {{ block.settings.padding_horizontal }}px;
                padding-right: {{ block.settings.padding_horizontal }}px;
            {%- endif -%}
        {%- endcapture -%}

        {%- capture image_style -%}
            {%- if block.settings.image_width > 0 -%}
                width: {{ block.settings.image_width }}px;
                height: {{ block.settings.image_width }}px;
            {%- endif -%}

            {%- if block.settings.image_alpha > 0 -%}
                opacity: {{ 100 | minus: block.settings.image_alpha | divided_by: 100.0 }};
            {%- endif -%}
        {%- endcapture -%}

        <div class="ccpc ccpc-display product-information-bullet-points {% if block.settings.two_columns %} product-information-bullet-points-two-columns{% endif %}" style="{{ style | strip_newlines }}">
            {% assign text1Plain = block.settings.text_1 | strip_html | strip_newlines %}
            {% assign text2Plain = block.settings.text_2 | strip_html | strip_newlines %}
            {% assign text3Plain = block.settings.text_3 | strip_html | strip_newlines %}
            {% assign text4Plain = block.settings.text_4 | strip_html | strip_newlines %}
            {% assign text5Plain = block.settings.text_5 | strip_html | strip_newlines %}
            {% assign text6Plain = block.settings.text_6 | strip_html | strip_newlines %}
            
            {%- if text1Plain != blank -%}
                <div {% render 'overwrite-theme-style', text_color: block.settings.text_color, font_size: block.settings.font_size, append_style: div_style %}>
                    {% render 'image', image: block.settings.image_1, style: image_style, default_theme_icon: block.settings.default_theme_icon_1 %}
                    <span>{{ block.settings.text_1 }}</span>
                </div>
            {%- endif -%}
            {%- if text2Plain != blank -%}
                <div {% render 'overwrite-theme-style', text_color: block.settings.text_color, font_size: block.settings.font_size, append_style: div_style %}>
                    {% render 'image', image: block.settings.image_2, style: image_style, default_theme_icon: block.settings.default_theme_icon_2 %}
                    <span>{{ block.settings.text_2 }}</span>
                </div>
            {%- endif -%}
            {%- if text3Plain != blank -%}
                <div {% render 'overwrite-theme-style', text_color: block.settings.text_color, font_size: block.settings.font_size, append_style: div_style %}>
                    {% render 'image', image: block.settings.image_3, style: image_style, default_theme_icon: block.settings.default_theme_icon_3 %}
                    <span>{{ block.settings.text_3 }}</span>
                </div>
            {%- endif -%}
            {%- if text4Plain != blank -%}
                <div {% render 'overwrite-theme-style', text_color: block.settings.text_color, font_size: block.settings.font_size, append_style: div_style %}>
                    {% render 'image', image: block.settings.image_4, style: image_style, default_theme_icon: block.settings.default_theme_icon_4 %}
                    <span>{{ block.settings.text_4 }}</span>
                </div>
            {%- endif -%}
            {%- if text5Plain != blank -%}
                <div {% render 'overwrite-theme-style', text_color: block.settings.text_color, font_size: block.settings.font_size, append_style: div_style %}>
                    {% render 'image', image: block.settings.image_5, style: image_style, default_theme_icon: block.settings.default_theme_icon_5 %}
                    <span>{{ block.settings.text_5 }}</span>
                </div>
            {%- endif -%}
            {%- if text6Plain != blank -%}
                <div {% render 'overwrite-theme-style', text_color: block.settings.text_color, font_size: block.settings.font_size, append_style: div_style %}>
                    {% render 'image', image: block.settings.image_6, style: image_style, default_theme_icon: block.settings.default_theme_icon_6 %}
                    <span>{{ block.settings.text_6 }}</span>
                </div>
            {%- endif -%}
        </div>

    {% when "variant_picker" %}
        {%- if product.has_only_default_variant or product_set_exists -%}
            {%- continue -%}
        {%- endif -%}

        <div class="product-information-variant-picker-{{ block.settings.type }} variant-picker" data-select-variant-image="{%- if section.settings.show_variant_media and block.settings.scroll_to_variant_image -%}true{%- else -%}false{%- endif -%}" {% render 'overwrite-theme-style', settings: block.settings %}>
        {%- if block.settings.type == 'dropdown' -%}
            {%- for option in product.options_with_values -%}
                <div class="product-information-variant-picker-dropdown-variant {% if block.settings.hide_by_one_option and option.values.size == 1 %} hide {% endif %}" style="margin-bottom: {{ block.settings.margin_between_variants }}px;">
                    <label {% render 'overwrite-theme-style', text_color: block.settings.heading_text_color, font_size: block.settings.heading_font_size %}>{{ option.name }}</label>
                    <select class="product-variant-select" name="{{ option.name | escape }}">
                        {%- for value in option.values -%}
                            <option value="{{ value | escape }}" {% if option.selected_value == value %}selected="selected"{% endif %}>
                                {{ value }}
                            </option>
                        {%- endfor -%}
                    </select>
                </div>
            {%- endfor -%}
        {%- else -%}
            {%- for option in product.options_with_values -%}

                {% assign variant_image_option_index = forloop.index %}

                {% assign variant_image_display_allowed = false %}
                {% if block.settings.variant_image_view_type == 'all' %}
                    {% assign variant_image_display_allowed = true %}   
                {% elsif block.settings.variant_image_view_type == 'first' %}
                    {% assign variant_image_display_allowed = forloop.first %}
                {% endif %}

                {% assign color_product_option_name = blank %}

                {% if block.settings.color_product_option_metafield_name != blank %}
                    {% assign metafield_brackets = block.settings.color_product_option_metafield_name | split: "." %}
                    {% assign metafield_brackets_size = metafield_brackets | size %}

                    {% if metafield_brackets_size < 2 %}
                        {% assign color_product_option_name = product.metafields[metafield_brackets[0]] | strip %}
                    {% else if metafield_brackets_size == 2 %}
                        {% assign color_product_option_name = product.metafields[metafield_brackets[0]][metafield_brackets[1]] | strip %}
                    {% endif %}
                {% endif %}

                <div class="product-information-variant-picker-button-variant {% if block.settings.type == 'button_box' %} product-information-variant-picker-button-box font-heading{% endif %} {% if block.settings.hide_by_one_option and option.values.size == 1 %} hide {% endif %}" style="margin-bottom: {{ block.settings.margin_between_variants }}px;">
                    <label {% render 'overwrite-theme-style', text_color: block.settings.heading_text_color, font_size: block.settings.heading_font_size %}>
                        <span>{{ option.name }}{% if block.settings.type == 'button' %}:{% endif %}<div></div></span>
                        <span data-color-swatch="{% if color_product_option_name != blank and color_product_option_name == option.name %}true{% else %}false{% endif %}">
                            {% if color_product_option_name != blank and color_product_option_name == option.name %}
                                <span class="color-swatch"></span>
                            {% else %}
                                {%- for value in option.values -%}
                                    {{ value }}
                                    {% break %}
                                {%- endfor -%}
                            {% endif %}
                        </span>
                        {% render 'icon-arrow-right' %}
                    </label>
                    <div class="product-information-variant-picker-button-variants">
                        {%- for value in option.values -%}
                            {% assign color_variant = null %}
                            {% assign color_swatch_color = null %}

                            {% if color_product_option_name != blank and color_product_option_name == option.name %}
                                {% for variant in product.variants %}
                                    {% if variant.options contains value %}
                                        {% assign color_variant = variant %}
                                        {% break %}
                                    {% endif %}
                                {% endfor %}

                                {% if color_variant != blank %}
                                    {% assign metafield_brackets = block.settings.color_metafield_name | split: "." %}
                                    {% assign metafield_brackets_size = metafield_brackets | size %}

                                    {% if metafield_brackets_size < 2 %}
                                        {% assign color_swatch_color = color_variant.metafields[metafield_brackets[0]] %}
                                    {% else if metafield_brackets_size == 2 %}
                                        {% assign color_swatch_color = color_variant.metafields[metafield_brackets[0]][metafield_brackets[1]] %}
                                    {% endif %}
                                {% endif %}
                            {% endif %}

                            {% assign image_variant = blank %}

                            {% if color_swatch_color == blank and variant_image_display_allowed %}
                                {% assign variant_image_options = blank %}
                                {% if block.settings.variant_image_options != blank %}
                                    {% assign metafield_brackets = block.settings.variant_image_options | split: "." %}
                                    {% assign metafield_brackets_size = metafield_brackets | size %}

                                    {% if metafield_brackets_size < 2 %}
                                        {% assign variant_image_options = product.metafields[metafield_brackets[0]].value %}
                                    {% else if metafield_brackets_size == 2 %}
                                        {% assign variant_image_options = product.metafields[metafield_brackets[0]][metafield_brackets[1]].value %}
                                    {% endif %}
                                {% endif %}

                                {% assign variant_option_property = 'option' | append: variant_image_option_index %}

                                {% for variant in product.variants %}
                                    {% if variant[variant_option_property] contains value and variant.image %}
                                        {% if variant_image_options == blank %}
                                            {% assign image_variant = variant %}
                                        {% elsif variant_image_options contains option.name %}
                                            {% assign image_variant = variant %}
                                        {% endif %}
                                    {% endif %}
                                {% endfor %}
                            {% endif %}

                            <div class="product-information-variant-picker-button-variant-option {% if color_swatch_color != blank %} color-swatch{% endif %} {% if image_variant != blank %} image-picker{% endif %}" style="background-color: {{ block.settings.variant_image_background_color }}; border-color: {{ block.settings.variant_image_background_color }};" data-option="{{ value }}">
                                <input 
                                    class="product-variant-radio"
                                    type="radio" 
                                    name="{{ option.name }}"
                                    value="{{ value | escape }}"
                                    {% if option.selected_value == value %}checked{% endif %}>

                                <span for="option-{{ option.position }}-{{ forloop.index0 }}" {% if color_swatch_color != blank %} style="background-color: {{ color_swatch_color }};"{% endif %}>
                                    {% if color_swatch_color == blank %}

                                        {% if image_variant != blank %}
                                            {%- capture style -%}
                                                width: {{ block.settings.variant_image_width }}px;
                                            {%- endcapture -%}

                                            {% render 'image', image: image_variant.image, style: style %}
                                        {% else %}
                                            {{ value }}
                                        {% endif %}

                                    {% endif %}
                                </span>

                                {% render 'icon-checkmark' %}
                            </div>
                        {%- endfor -%}
                    </div>
                </div>
            {%- endfor -%}
        {%- endif -%}
        </div>

