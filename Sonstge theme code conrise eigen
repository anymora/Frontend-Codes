    {% when "image_and_video" %}
        <div {% render 'overwrite-theme-style', settings: block.settings %}>
            {%- if block.settings.use_image != blank -%}
                {%- capture image_style -%}
                    {%- if block.settings.image_width > 0 -%}
                        width: {{ block.settings.image_width }}%;
                    {%- endif -%}
                {%- endcapture -%}
                {% render 'image', image: block.settings.use_image, style: image_style %}
            {%- else -%}
                <div class="video-banner">
                    <div class="video-banner-video">
                        {%- if block.settings.video_webm != blank or block.settings.video_mp4 != blank or block.settings.video_mov != blank -%}
                            <video class="product-image-and-video-video-container" autoplay playsinline {% if block.settings.mute_video %} muted {% endif %} loop>
                                {% if block.settings.video_webm != blank %}
                                    <source src="{{ block.settings.video_webm }}" type="video/webm">
                                {% endif %}
                                {% if block.settings.video_mp4 != blank %}
                                    <source src="{{ block.settings.video_mp4 }}" type="video/mp4">
                                {% endif %}
                                {% if block.settings.video_mov != blank %}
                                    <source src="{{ block.settings.video_mov }}" type="video/mp4">
                                {% endif %}
                            </video>
                        {%- endif -%}
                    </div>
                </div>
            {%- endif -%}
        </div>
