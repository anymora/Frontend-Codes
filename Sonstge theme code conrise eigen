<input type="hidden" class="product-information-quantity-field hide" name="quantity" min="1" value="1">

{% if product_page_button_exists == true %}
    <div class="product-page-button-overlay">
        <div class="product-page-button-popup">
            {% render 'icon-close' %}
        </div>
    </div>
{% endif %}

<script>
    var cr_product = {{ product | json }};
    var cr_productWeight = {};
    var cr_variantStock = {};

    {% for variant in product.variants %}
        {% if variant.inventory_management == 'shopify' and variant.inventory_policy == 'deny' %}
            cr_variantStock[{{- variant.id -}}] = {{ variant.inventory_quantity | at_least: 0 }};
        {% endif %}

        cr_productWeight[{{- variant.id -}}] = '{{ variant.weight_in_unit }} {{ variant.weight_unit }}';
    {% endfor %}
</script>

{%- endform -%}

